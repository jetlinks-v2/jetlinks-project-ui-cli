{
  "name": "jetlinks-ui-cli",
  "private": true,
  "scripts": {
    "build": "pnpm --filter scripts build",
    "dev": "pnpm --filter scripts dev",
    "compile": "pnpm turbo run compile",
    "compile-es": "pnpm turbo run compile-es",
    "turbo:build": "turbo run build --parallel",
    "turbo:dev": "turbo run dev --parallel",
    "stub": "pnpm --filter @jetlinks/** prepack",
    "clean": "pnpm turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "version": "pnpm run changeset version",
    "release:only": "changeset publish --access=public",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3",
    "@jetlinks-web/constants": "workspace:^",
    "@jetlinks-web/core": "workspace:^",
    "@jetlinks-web/hooks": "workspace:^",
    "@jetlinks-web/lint": "workspace:^",
    "@jetlinks-web/tsconfig": "workspace:*",
    "@jetlinks-web/types": "workspace:^",
    "@jetlinks-web/utils": "workspace:^",
    "@storybook/addon-docs": "^8.6.10",
    "@storybook/addon-essentials": "8.6.9",
    "@storybook/addon-onboarding": "8.6.9",
    "@storybook/blocks": "8.6.9",
    "@storybook/experimental-addon-test": "8.6.9",
    "@storybook/manager-api": "^8.6.9",
    "@storybook/test": "8.6.9",
    "@storybook/theming": "8.6.9",
    "@storybook/vue3": "8.6.9",
    "@storybook/vue3-vite": "8.6.9",
    "@turbo/gen": "^1.10.12",
    "@types/node": "^20.4.5",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vitest/browser": "^3.0.9",
    "@vitest/coverage-v8": "^3.0.9",
    "@vue/shared": "^3.4.21",
    "eslint": "^7.32.0",
    "eslint-plugin-storybook": "^0.12.0",
    "eslint-plugin-vue": "^9.23.0",
    "esno": "^0.16.3",
    "lodash-es": "^4.17.21",
    "playwright": "^1.51.1",
    "prettier": "^2.8.8",
    "raw-loader": "^4.0.2",
    "rimraf": "^5.0.1",
    "storybook": "8.6.9",
    "ts-node": "^10.9.1",
    "turbo": "^1.10.12",
    "typescript": "^5.1.6",
    "unbuild": "^1.2.1",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@7.15.0",
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@changesets/cli": "^2.26.2",
    "@jetlinks-web/components": "workspace:^",
    "ant-design-vue": "^3.2.20",
    "vite": "^6.2.3",
    "vue": "^3.3.4"
  }
}
