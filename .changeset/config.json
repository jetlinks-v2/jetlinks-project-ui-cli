    "jetlinks-ai-agent-ui",
    "jetlinks-aliyun-bridge-gateway-ui",
    "jetlinks-components-ui",
    "jetlinks-dueros-ui",
    "jetlinks-function-ui",
    "jetlinks-knowledge-ui",
    "jetlinks-media-ui",
    "network-card-manager-ui",
    "notify-manager-ui",
    "rule-engine-manager-ui",
    "visualization-dashboard-ui",
    "visualization-designer-ui",
    "visualization-manager-ui",
    "visualization-model-ui",
    "visualization-resources"
